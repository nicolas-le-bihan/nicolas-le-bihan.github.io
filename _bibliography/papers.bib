@inproceedings{chatelain2019gretsi,
abbr={GRETSI},
author={Chatelain, F. and {Le Bihan}, N.},
title={Régime asymptotique des statistiques de test de circularité},
booktitle={{27ème Colloque Francophone de Traitement du Signal et des Images (GRETSI)}},
year={2019},
pages={1177--1180},
address={Lille, France},
abstract={Dans le cas Gaussien, tester la circularité d'un vecteur aléatoire complexe revient à identifier une structure de corrélation spécifique entre la partie réelle et la partie imaginaire. Dans cet article, nous nous intéressons à définir un test invariant par transformation linéaire, ce qui revient à construire un tel test à l'aide des valeurs propres de la matrice de corrélation empirique des observations. Nous donnons la distribution des valeurs propres ainsi que de la valeur propre maximale dans le régime asymptotique où la taille des vecteurs et la taille de l'échantillon tendent vers l'infini pendant que leur rapport reste commensurable. Enfin, nous comparons dans ce régime asymptotique le test de Roy, qui repose sur la statistique de la plus grande valeur propre, avec le GLRT sur des simulations.},
bibtex_show={}
}

